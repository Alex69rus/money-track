{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python BE (backend_new)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend_new/.venv/bin/python",
            "module": "uvicorn",
            "cwd": "${workspaceFolder}/backend_new",
            "envFile": "${workspaceFolder}/backend_new/.env",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
