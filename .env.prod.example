# Copy this file to the untracked .env.prod only for an isolated local production-compose test.
# GitHub Actions writes the real /opt/money-track/.env.prod from Actions secrets and variables.
POSTGRES_DB=moneytrack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-secret
TELEGRAM_BOT_TOKEN=replace-with-a-secret
TELEGRAM_WEBHOOK_URL=https://money-track.org/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-a-secret
TELEGRAM_WEB_APP_URL=https://money-track.org
CORS_ALLOW_ORIGINS=https://money-track.org
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
N8N_ENCRYPTION_KEY=replace-with-a-secret
ENVIRONMENT=Production
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_IMAGE=ghcr.io/alex69rus/money-track/backend:latest
FRONTEND_IMAGE=ghcr.io/alex69rus/money-track/frontend-new:latest
DOMAIN=money-track.org
